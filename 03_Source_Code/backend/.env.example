# Database PostgreSQL untuk backend.
DATABASE_URL=postgresql://user:password@localhost:5432/ki_ipb

# JWT signing secret. Gunakan nilai random minimal 32 karakter.
SECRET_KEY=your-super-secret-key-min-32-chars-random

# Algoritma JWT.
ALGORITHM=HS256

# Fernet key base64 untuk enkripsi purpose dan notes tiket. Generate dengan: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-base64

# Lokasi RSA private key untuk digital signature. File .pem tidak boleh dicommit.
PRIVATE_KEY_PATH=keys/private_key.pem

# Lokasi RSA public key untuk verifikasi signature. File .pem tidak boleh dicommit.
PUBLIC_KEY_PATH=keys/public_key.pem

# Origin frontend yang boleh mengirim request credentialed CORS.
ALLOWED_ORIGINS=http://localhost:5173

# Expiry access token dalam menit.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Expiry refresh token dalam hari.
REFRESH_TOKEN_EXPIRE_DAYS=7

# development atau production. Production mengaktifkan trusted host / HTTPS behavior.
ENVIRONMENT=development

# Set true hanya untuk setup development lokal jika ingin SQLAlchemy membuat tabel otomatis.
AUTO_CREATE_TABLES=false

# URL frontend untuk link notifikasi.
FRONTEND_URL=http://localhost:5173

# Folder upload relatif terhadap backend.
UPLOAD_DIR=uploads
