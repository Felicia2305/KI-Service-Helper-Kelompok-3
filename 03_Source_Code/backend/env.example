# Salin file ini ke .env lalu isi nilainya.
DATABASE_URL=postgresql://user:password@localhost:5432/ki_ipb
SECRET_KEY=your-super-secret-key-min-32-chars-random
ALGORITHM=HS256
FERNET_KEY=your-fernet-key-base64
PRIVATE_KEY_PATH=keys/private_key.pem
PUBLIC_KEY_PATH=keys/public_key.pem
ALLOWED_ORIGINS=http://localhost:5173
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development
AUTO_CREATE_TABLES=false
FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=uploads
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@iash.ipb.ac.id
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
